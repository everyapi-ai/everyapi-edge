# EveryAPI edge agent — copy to .env and fill in the supplier-specific
# values. Required fields are marked REQUIRED; everything else is
# optional metadata that helps the dashboard render useful badges and
# helps buyers filter for "EU node" / "RTX 4090 only" etc.

# REQUIRED — base URL of the EveryAPI gateway.
EVERYAPI_GATEWAY=https://api.everyapi.ai

# REQUIRED — paste from the dashboard after you click "New node".
EVERYAPI_NODE_ID=

# REQUIRED on first run ONLY. After the first successful connect this
# value is consumed server-side; you can blank it out and the agent
# will continue authenticating with its Ed25519 identity. Leaving the
# expired value in place is harmless but the gateway will reject
# attempted reuse.
EVERYAPI_REGISTRATION_TOKEN=

# Optional metadata — empty values just don't get reported.
EVERYAPI_NODE_NAME=home-rtx4090
EVERYAPI_GPU_MODEL=NVIDIA GeForce RTX 4090
EVERYAPI_VRAM_GB=24
EVERYAPI_COUNTRY=US

# Pin the agent image version. Floating to :latest is OK for early
# adopters; ops-conscious suppliers should pin to a specific tag.
EVERYAPI_EDGE_VERSION=latest
